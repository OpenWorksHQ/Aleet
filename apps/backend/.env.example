# Server
PORT=5000
NODE_ENV=development
APP_BASE_URL=http://localhost:3001
# Customer site URL — used for Stripe success/cancel redirects when APP_BASE_URL is unset
FRONTEND_URL=http://localhost:3001
DRIVER_PORTAL_URL=http://localhost:3002
# Comma-separated extra browser origins (e.g. Vercel preview URLs)
ALLOWED_ORIGINS=
# Set to false to disable auto-allow *.vercel.app (default: allowed)
# ALLOW_VERCEL_ORIGINS=false
API_URL=http://localhost:5000

# Database
MONGODB_URI=

# Auth
JWT_SECRET=
# Optional. Default is 7d (matches admin/driver portal cookies).
JWT_EXPIRES_IN=7d
SESSION_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# AWS S3
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Checkr
CHECKR_API_KEY=

# Google Maps
GOOGLE_MAPS_API_KEY=

# Email (Gmail SMTP — use a Google App Password, not your login password)
# GMAIL_USER           = Gmail account for SMTP login (base address, no +alias)
# GMAIL_FROM_EMAIL     = From address shown to recipients (may use +alias)
# INVESTOR_INBOX_EMAIL = where /teams form submissions are delivered
GMAIL_USER=
GMAIL_FROM_EMAIL=
GMAIL_APP_PASSWORD=
INVESTOR_INBOX_EMAIL=
